# ============================================
# IRON ECHELON — Environment Variables
# ============================================

# ------ DATABASE (Required) ------
# Local development: use file path
DATABASE_URL="file:./dev.db"

# Production (Turso): hosted LibSQL database
# Get these from https://turso.tech after creating a database
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ------ SECURITY (Recommended for production) ------
# Secret to authenticate Vercel Cron job requests to /api/sync/surveillance-watch
CRON_SECRET="generate-a-random-string-here"
